SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENROUTER_PROVISIONING_KEY=
# OpenRouter named key for BillFlow's Orion assistant — must match the "billflow" entry in agents_portfolio
# Get from: https://openrouter.ai/settings/keys
OPENROUTER_BILLFLOW_API_KEY=
NEXT_PUBLIC_BASE_URL=https://spendsync-production.up.railway.app

# To send from a custom domain (e.g. noreply@fello.ai), verify the domain in
# Resend dashboard (resend.com/domains) and update the `from` field in all edge
# functions (notify-admin, send-otp, guardrail-check).
RESEND_FROM_ADDRESS=BillFlow <onboarding@resend.dev>

# Resend API key for spend alert emails (guardrail-check edge function)
RESEND_API_KEY=

# Comma-separated list of alert recipients; defaults to full team if omitted
# GUARDRAIL_ALERT_EMAIL=shailja.dwivedi@fello.ai,nikhil@fello.ai,riyon@fello.ai,aryan.pasreja@fello.ai,rashi@fello.ai,hemanth@fello.ai,adarsh.badjate@fello.ai,madangopal.boddu@fello.ai,arpan@fello.ai,amit@fello.ai,innovations@fello.ai
